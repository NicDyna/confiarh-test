# Copy these into Railway -> your service -> Variables.
# (This file is only documentation. Do not commit a real .env with secrets.)

# --- Odoo connection (required) ---
ODOO_URL=https://your-database.odoo.com
ODOO_DB=your-database-name
ODOO_USERNAME=api-user@confiarh.lu
ODOO_API_KEY=your-odoo-api-key

# --- Optional: only set if the Studio field names ever change ---
# PARTNER_PIN_FIELD=x_studio_pin
# JOB_PARTNER_FIELD=x_studio_many2one_field_5j_1jrv1qb8f

# --- Optional: session signing key ---
# SECRET_KEY=change-me
